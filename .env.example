# Local development database. Set credentials in your private .env; never commit real ones.
# Example shape: postgresql+psycopg://<user>:<password>@localhost:5432/lms_dev
DATABASE_URL=postgresql+psycopg://localhost:5432/lms_dev
DATABASE_ECHO=false

# LLM provider keys. Leave blank until configured in a private .env file or GitHub secret.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LANGSMITH_API_KEY=

# LLM mode routing. Values are examples only and may change as model policy evolves.
LLM_MODEL_STUDY_COACH=anthropic:claude-sonnet-4-5
LLM_MODEL_PRACTICE=anthropic:claude-sonnet-4-5
LLM_DAILY_BUDGET_USD=5.00

# LangSmith tracing. Keep disabled locally unless trace redaction/classification is configured.
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=lms-local
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Local prototype auth posture. SSO is not implemented in v1, but identity fields stay SSO-ready.
LMS_AUTH_MODE=local
# Leave blank so missing config is loud; generate a real value in your private .env (e.g. `python -c 'import secrets; print(secrets.token_urlsafe(48))'`).
LMS_SESSION_SECRET=
